# Configuración de la base de datos PostgreSQL
# Copia este archivo como .env y ajusta los valores según tu configuración

# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
# Desarrollo local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/futbol_db

# Para Railway (se configura automáticamente desde PostgreSQL service):
# DATABASE_URL=postgresql://postgres:xxx@xxx.railway.app:5432/railway

# Entorno (Railway lo configura automáticamente)
# RAILWAY_ENVIRONMENT=production
